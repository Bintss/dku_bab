# 데이터베이스 접속을 위한 env 정보 템플릿.
# 이 파일을 복사하여 .env 파일을 만들고 실제 값 채우기.
# Django가 읽어갈 DB 정보 !!중요!!: DB_HOST는 'localhost'가 아니라 docker-compose.yml에 정의된 서비스 이름인 'db'.
DB_HOST=db
DB_PORT=3306
DB_NAME=cafeteria_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_root_password

DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_DEBUG=True